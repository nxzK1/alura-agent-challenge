# Copiar este archivo como .env y completar con tus propios valores.
# Nunca subir el archivo .env real al repositorio.

# Ruta al modelo Gemma (si se descarga localmente) o identificador del modelo en Hugging Face
GEMMA_MODEL_ID=google/gemma-2b-it

# Directorio donde se guardan los documentos cargados por el usuario
DOCUMENTS_DIR=./data

# (Opcional) API key de Hugging Face, si el modelo requiere autenticación
HUGGINGFACE_TOKEN=
